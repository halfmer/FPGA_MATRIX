    <general_container id="device_map_timing_constraint">
        <table_container>
            <table id="device_map_timing_constraint" title="Timing Constraint" column_number="1">
                <column_headers>
                    <data>Command</data>
                </column_headers>
                <row>
                    <data>create_clock -name {clk} [get_ports clk] -period {40.000} -waveform {0.000 20.000}</data>
                </row>
            </table>
        </table_container>
        <table_container>
            <table id="device_map_timing_constraint" title="Inferred clocks commands" column_number="1">
                <column_headers>
                    <data>Command</data>
                </column_headers>
                <row>
                    <data>create_generated_clock -name {clk|u_clk_0/u_pll_e3/CLKOUT0_Inferred} -master_clock {clk} -source [get_ports {clk}] -edges {1 2 3} -edge_shift {0.000000 -15.000000 -30.000000} [get_pins {u_clk_0/u_pll_e3.CLKOUT0}] -add</data>
                </row>
            </table>
        </table_container>
    </general_container>
</tables>